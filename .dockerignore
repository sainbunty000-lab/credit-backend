# Version control
.git
.gitignore

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Virtual environments
.venv/
venv/
env/

# Environment files (never bake secrets into the image)
.env
.env.*
!.env.example

# Local database (use Cloud SQL in production)
*.db
*.sqlite
*.sqlite3

# Test artifacts
.pytest_cache/
.coverage
htmlcov/

# Editor / OS metadata
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Temporary PDF downloads (generated at runtime in /tmp)
downloads/
